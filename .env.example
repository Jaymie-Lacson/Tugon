# Frontend environment
# Local development: use localhost backend
# Deployment (Vercel): replace with your Railway backend URL
# Example: https://your-railway-service.up.railway.app/api
VITE_API_BASE_URL="http://localhost:4000/api"

# Server environment
NODE_ENV=development
PORT=4000
JWT_SECRET="change-this-to-a-long-random-secret"
JWT_EXPIRES_IN=8h
OTP_EXPIRY_MINUTES=5

# Supabase PostgreSQL connection string for Prisma (direct connection, required for migrations)
# Important: use your real password directly (do not include [] brackets).
# If your host cannot reach direct IPv6, use Supabase Session Pooler URI instead.
DATABASE_URL="postgresql://postgres:<PASSWORD>@<PROJECT-REF>.supabase.co:5432/postgres?sslmode=require"
