{
  "name": "tugon-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build && node dist/server.js",
    "build": "tsc -p tsconfig.json",
    "test:integration": "tsx --test tests/**/*.test.ts",
    "test": "npm run test:integration",
    "start": "node dist/server.js",
    "start:prod": "if [ \"$RUN_DB_MIGRATIONS\" = \"1\" ]; then npm run prisma:migrate:deploy; else echo 'Skipping prisma migrations (set RUN_DB_MIGRATIONS=1 to enable)'; fi && npm run start",
    "deploy:railway:check": "node scripts/railway-preflight.cjs",
    "seed": "tsx prisma/seed.ts",
    "seed:screenshots": "tsx prisma/seed-screenshots.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:resolve": "prisma migrate resolve",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:status": "prisma migrate status",
    "prisma:validate": "prisma validate",
    "prisma:seed": "npm run seed",
    "check:prod": "npm run prisma:validate && npm run prisma:generate && npm run build && npm run prisma:status"
  },
  "dependencies": {
    "@figma/my-make-file": "file:..",
    "@prisma/client": "^6.19.2",
    "@supabase/supabase-js": "^2.57.4",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.12.0",
    "prisma": "^6.5.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2"
  }
}
