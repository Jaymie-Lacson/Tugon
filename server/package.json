{
  "name": "tugon-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:prod": "npm run prisma:migrate:deploy && npm run start",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:status": "prisma migrate status",
    "prisma:validate": "prisma validate",
    "check:prod": "npm run prisma:validate && npm run prisma:generate && npm run build && npm run prisma:status"
  },
  "dependencies": {
    "@figma/my-make-file": "file:..",
    "@prisma/client": "^6.19.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.12.0",
    "prisma": "^6.5.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2"
  }
}
