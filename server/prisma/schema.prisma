generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  fullName       String
  phoneNumber    String   @unique
  passwordHash   String?
  role           Role
  isPhoneVerified Boolean @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  citizenProfile CitizenProfile?
  officialProfile OfficialProfile?
}

model CitizenProfile {
  id         String   @id @default(cuid())
  userId     String   @unique
  barangayId String
  address    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  barangay Barangay @relation(fields: [barangayId], references: [id])
}

model OfficialProfile {
  id         String   @id @default(cuid())
  userId     String   @unique
  barangayId String
  position   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  barangay Barangay @relation(fields: [barangayId], references: [id])
}

model Barangay {
  id             String   @id @default(cuid())
  name           String
  code           String   @unique
  boundaryGeojson String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  citizens CitizenProfile[]
  officials OfficialProfile[]
}

model CitizenReport {
  id             String         @id
  citizenUserId  String
  routedBarangayCode String
  latitude       Float
  longitude      Float
  category       String
  subcategory    String
  requiresMediation Boolean      @default(false)
  mediationWarning String?
  status         TicketStatus   @default(SUBMITTED)
  location       String
  barangay       String
  district       String
  description    String
  severity       ReportSeverity
  affectedCount  String?
  submittedAt    DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  hasPhotos      Boolean        @default(false)
  photoCount     Int            @default(0)
  hasAudio       Boolean        @default(false)
  assignedOfficer String?
  assignedUnit   String?
  resolutionNote String?

  statusHistory TicketStatusHistory[]
  crossBorderAlerts CrossBorderAlert[]
  evidences IncidentEvidence[]
}

model IncidentEvidence {
  id              String   @id @default(cuid())
  reportId        String
  kind            String
  storageProvider String
  storagePath     String?
  publicUrl       String?
  fileName        String
  mimeType        String
  sizeBytes       Int
  createdAt       DateTime @default(now())

  report CitizenReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId, createdAt])
}

model CrossBorderAlert {
  id                String   @id @default(cuid())
  reportId          String
  sourceBarangayCode String
  targetBarangayCode String
  alertReason       String
  createdAt         DateTime @default(now())
  readAt            DateTime?

  report CitizenReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([targetBarangayCode, createdAt])
  @@unique([reportId, targetBarangayCode])
}

model TicketStatusHistory {
  id          String       @id @default(cuid())
  reportId    String
  status      TicketStatus
  label       String
  description String
  actor       String
  actorRole   String
  note        String?
  createdAt   DateTime     @default(now())

  report CitizenReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId, createdAt])
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  actorUserId String
  action      String
  targetType  String
  targetId    String?
  targetLabel String?
  details     String?
  createdAt   DateTime @default(now())

  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
}

enum Role {
  CITIZEN
  OFFICIAL
  SUPER_ADMIN
}

enum TicketStatus {
  SUBMITTED
  UNDER_REVIEW
  IN_PROGRESS
  RESOLVED
  CLOSED
  UNRESOLVABLE
}

enum ReportSeverity {
  low
  medium
  high
  critical
}
