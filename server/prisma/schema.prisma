generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  fullName       String
  phoneNumber    String   @unique
  passwordHash   String?
  role           Role
  isPhoneVerified Boolean @default(false)
  isVerified     Boolean  @default(false) @map("is_verified")
  idImageUrl     String?  @map("id_image_url")
  verificationStatus VerificationStatus? @map("verification_status")
  verificationRejectionReason String? @map("verification_rejection_reason")
  verifiedByUserId String? @map("verified_by_user_id")
  verifiedAt     DateTime? @map("verified_at")
  isBanned       Boolean @default(false) @map("is_banned")
  bannedAt       DateTime? @map("banned_at")
  bannedReason   String? @map("banned_reason")
  bannedByUserId String? @map("banned_by_user_id")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  citizenProfile CitizenProfile?
  officialProfile OfficialProfile?
  reports        CitizenReport[]
}

model CitizenProfile {
  id         String   @id @default(cuid())
  userId     String   @unique
  barangayId String
  address    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  barangay Barangay @relation(fields: [barangayId], references: [id])
}

model OfficialProfile {
  id         String   @id @default(cuid())
  userId     String   @unique
  barangayId String
  position   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  barangay Barangay @relation(fields: [barangayId], references: [id])
}

model Barangay {
  id             String   @id @default(cuid())
  name           String
  code           String   @unique
  boundaryGeojson String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  citizens CitizenProfile[]
  officials OfficialProfile[]
}

model CitizenReport {
  id             String         @id
  citizenUserId  String
  routedBarangayCode String
  latitude       Float
  longitude      Float
  category       String
  subcategory    String
  requiresMediation Boolean      @default(false)
  mediationWarning String?
  status         TicketStatus   @default(SUBMITTED)
  location       String
  barangay       String
  district       String
  description    String
  severity       ReportSeverity
  affectedCount  String?
  submittedAt    DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  hasPhotos      Boolean        @default(false)
  photoCount     Int            @default(0)
  hasAudio       Boolean        @default(false)
  assignedOfficer String?
  assignedUnit   String?
  resolutionNote String?

  citizen       User                  @relation(fields: [citizenUserId], references: [id], onDelete: Cascade)
  statusHistory TicketStatusHistory[]
  crossBorderAlerts CrossBorderAlert[]
  evidences IncidentEvidence[]

  @@index([citizenUserId])
}

model IncidentEvidence {
  id              String   @id @default(cuid())
  reportId        String
  kind            String
  storageProvider String
  storagePath     String?
  publicUrl       String?
  fileName        String
  mimeType        String
  sizeBytes       Int
  createdAt       DateTime @default(now())

  report CitizenReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId, createdAt])
}

model CrossBorderAlert {
  id                String   @id @default(cuid())
  reportId          String
  sourceBarangayCode String
  targetBarangayCode String
  alertReason       String
  createdAt         DateTime @default(now())
  readAt            DateTime?

  report CitizenReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([targetBarangayCode, createdAt])
  @@unique([reportId, targetBarangayCode])
}

model TicketStatusHistory {
  id          String       @id @default(cuid())
  reportId    String
  status      TicketStatus
  label       String
  description String
  actor       String
  actorRole   String
  note        String?
  createdAt   DateTime     @default(now())

  report CitizenReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId, createdAt])
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  actorUserId String
  action      String
  targetType  String
  targetId    String?
  targetLabel String?
  details     String?
  createdAt   DateTime @default(now())

  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
}

model AdminNotification {
  id              String   @id @default(cuid())
  recipientUserId String
  kind            String
  title           String
  message         String
  reportId        String?
  metadata        String?
  createdAt       DateTime @default(now())
  readAt          DateTime?

  @@index([recipientUserId, readAt, createdAt])
  @@index([reportId, createdAt])
}

model AuthSession {
  id         String   @id @default(cuid())
  sessionId  String   @unique
  userId     String
  tokenHash  String   @unique
  issuedAt   DateTime
  expiresAt  DateTime
  revokedAt  DateTime?
  revokeReason String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model OtpChallenge {
  id                  String   @id @default(cuid())
  phoneNumber         String
  purpose             OtpPurpose
  codeHash            String
  expiresAt           DateTime
  isVerified          Boolean  @default(false)
  failedVerifyAttempts Int     @default(0)
  lockoutUntil        DateTime?
  lastSentAt          DateTime
  registrationFullName String?
  registrationBarangayCode String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([phoneNumber, purpose])
  @@index([expiresAt])
}

model IpRateLimitBucket {
  bucketKey     String   @id
  windowStartMs BigInt
  count         Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([updatedAt])
}

enum Role {
  CITIZEN
  OFFICIAL
  SUPER_ADMIN
}

enum TicketStatus {
  SUBMITTED
  UNDER_REVIEW
  IN_PROGRESS
  RESOLVED
  CLOSED
  UNRESOLVABLE
}

enum ReportSeverity {
  low
  medium
  high
  critical
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
  REUPLOAD_REQUESTED
}

enum OtpPurpose {
  REGISTRATION
  PASSWORD_RESET
}
