{
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "bitloops hooks claude-code post-task",
            "type": "command"
          }
        ],
        "matcher": "Task"
      },
      {
        "hooks": [
          {
            "command": "bitloops hooks claude-code post-tool-use",
            "type": "command"
          }
        ],
        "matcher": "^(?!Task$|TodoWrite$).+"
      },
      {
        "hooks": [
          {
            "command": "bitloops hooks claude-code post-todo",
            "type": "command"
          }
        ],
        "matcher": "TodoWrite"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "bitloops hooks claude-code pre-task",
            "type": "command"
          }
        ],
        "matcher": "Task"
      },
      {
        "hooks": [
          {
            "command": "bitloops hooks claude-code pre-tool-use",
            "type": "command"
          }
        ],
        "matcher": "^(?!Task$|TodoWrite$).+"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "bitloops hooks claude-code session-end",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bitloops hooks claude-code session-start",
            "type": "command"
          }
        ],
        "matcher": "startup|resume|clear|compact"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "bitloops hooks claude-code stop",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "bitloops hooks claude-code user-prompt-submit",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npm run build*)",
      "Bash(npm run build:server*)",
      "Bash(npm run check:prod*)",
      "Bash(npm --prefix server run prisma:validate*)",
      "Bash(npm --prefix server run prisma:generate*)",
      "Bash(npm --prefix server run prisma:status*)",
      "Bash(npm --prefix server run prisma:migrate:deploy*)",
      "Bash(npm --prefix server run build*)",
      "Bash(npm --prefix server run test:integration*)",
      "Bash(npx tsc --noEmit*)",
      "mcp__code-review-graph__build_or_update_graph_tool",
      "mcp__code-review-graph__semantic_search_nodes_tool",
      "mcp__code-review-graph__detect_changes_tool",
      "mcp__code-review-graph__get_review_context_tool",
      "mcp__code-review-graph__query_graph_tool",
      "mcp__code-review-graph__get_impact_radius_tool",
      "mcp__code-review-graph__get_affected_flows_tool",
      "mcp__code-review-graph__get_architecture_overview_tool",
      "mcp__code-review-graph__list_communities_tool",
      "mcp__code-review-graph__list_flows_tool",
      "mcp__code-review-graph__find_large_functions_tool",
      "mcp__code-review-graph__refactor_tool",
      "mcp__code-review-graph__get_minimal_context_tool"
    ]
  }
}
