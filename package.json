{
  "name": "@figma/my-make-file",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "build:analyze": "cross-env ANALYZE=true vite build",
    "dev": "vite",
    "test:frontend": "vitest run",
    "test:frontend:watch": "vitest",
    "test:frontend:a11y": "node scripts/a11y-smoke.cjs",
    "test:frontend:all": "npm run test:frontend && npm run test:frontend:a11y",
    "build:server": "npm --prefix server run build",
    "audit:security": "npm audit --omit=dev --audit-level=high && npm --prefix server run audit:security",
    "prisma:generate": "npm --prefix server run prisma:generate",
    "prisma:validate": "npm --prefix server run prisma:validate",
    "prisma:status": "npm --prefix server run prisma:status",
    "prisma:migrate:deploy": "npm --prefix server run prisma:migrate:deploy",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "check:prod": "npm run build && npm run build:server && npm run prisma:validate && npm run prisma:generate && npm run prisma:status"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.4",
